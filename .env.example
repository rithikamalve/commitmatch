# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ── DynamoDB ──────────────────────────────────────────────────────────────────
# Leave blank for real DynamoDB; set http://localhost:8000 for DynamoDB Local
DYNAMODB_ENDPOINT=

# ── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ── API Gateway WebSocket ─────────────────────────────────────────────────────
WEBSOCKET_ENDPOINT=https://your-id.execute-api.ap-south-1.amazonaws.com/prod
WEBSOCKET_API_ID=your_api_id

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=commitmatch-frontend

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Demo sandbox numbers (must be registered in Twilio sandbox) ───────────────
DEMO_PHONE_1=whatsapp:+91XXXXXXXXXX
DEMO_PHONE_2=whatsapp:+91XXXXXXXXXX

# ── App ───────────────────────────────────────────────────────────────────────
CSV_PATH=data/Dataset.csv
DEMO_MODE=true
DEMO_WHATSAPP=false
PORT=8000
FRONTEND_URL=http://localhost:3000
